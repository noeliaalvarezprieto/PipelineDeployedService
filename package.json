{
  "name": "poc1-app",
  "version": "1.0.0",
  "description": "Production-ready Express app for ECS Fargate",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --coverageReporters=lcov --coverageReporters=text",
    "test:unit": "jest src/__tests__/unit --coverage",
    "test:integration": "jest src/__tests__/integration --coverage",
    "lint": "eslint src --format junit --output-file reports/lint-results.xml"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/__tests__/**",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.0",
    "semver": "^5.7.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "3.0.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": "20.x"
  }
}
