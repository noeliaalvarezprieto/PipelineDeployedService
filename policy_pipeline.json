{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject","s3:PutObject","s3:GetObjectVersion","s3:GetBucketVersioning"],
      "Resource": ["arn:aws:s3:::poc1-app-artifacts-160823835871-eu-west-1","arn:aws:s3:::poc1-app-artifacts-160823835871-eu-west-1/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["codebuild:BatchGetBuilds","codebuild:StartBuild"],
      "Resource": ["arn:aws:codebuild:eu-west-1:160823835871:project/poc1-app-build","arn:aws:codebuild:eu-west-1:160823835871:project/poc1-app-test"]
    },
    {
      "Effect": "Allow",
      "Action": ["ecs:RegisterTaskDefinition","ecs:DescribeServices","ecs:UpdateService","ecs:DescribeTaskDefinition","ecs:DescribeClusters","ecs:ListTaskDefinitions","ecs:ListServices"],
      "Resource": ["arn:aws:ecs:eu-west-1:160823835871:cluster/poc1-cluster","arn:aws:ecs:eu-west-1:160823835871:service/poc1-cluster/poc1-prod-service","arn:aws:ecs:eu-west-1:160823835871:task-definition/poc1-app-task:*"]
    },
    {
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": "arn:aws:iam::160823835871:role/poc1-app-ecs-task-execution-role",
      "Condition": {"StringLike": {"iam:PassedToService": ["ecs.amazonaws.com","ecs-tasks.amazonaws.com"]}}
    },
    {
      "Effect": "Allow",
      "Action": ["codestar-connections:UseConnection"],
      "Resource": "arn:aws:codeconnections:eu-west-1:160823835871:connection/2b16d7d8-246c-4e94-9001-e91920438d97"
    },
    {
      "Effect": "Allow",
      "Action": ["sns:Publish"],
      "Resource": "arn:aws:sns:eu-west-1:160823835871:poc1-app-pipeline-notifications"
    }
  ]
}